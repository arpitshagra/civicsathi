# ---------------------------------------------------------------------------
# CivicSathi AI — environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Core Flask ---
SECRET_KEY=change-me-in-production
FLASK_ENV=production
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all.
CORS_ORIGINS=*

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Authentication ---
# When true, protected routes skip Firebase token verification and use a
# synthetic dev user. Useful for local testing WITHOUT live Firebase creds.
# NEVER enable in production.
AUTH_DISABLED=false

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_CHAT_TEMPERATURE=0.5
GROQ_MAX_TOKENS=2048

# --- Firebase ---
# Provide EITHER a path to a service-account JSON file...
FIREBASE_CREDENTIALS_PATH=civicaifirebase.json
# ...OR the service-account JSON inline (recommended on Render).
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# --- Input limits (abuse / cost control) ---
MAX_MESSAGE_LENGTH=4000
MAX_NOTIFICATION_LENGTH=20000
MAX_COMPLAINT_LENGTH=5000

# --- Dashboard ---
DASHBOARD_RECENT_LIMIT=5
