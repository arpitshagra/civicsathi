# ---------------------------------------------------------------------------
# CivicSathi AI — frontend environment (Vite)
# Copy to `.env.local` and fill in. All VITE_* vars are exposed to the browser.
# ---------------------------------------------------------------------------

# Backend base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000

# Firebase Web App config (Project settings → General → Your apps → Web app → Config)
# Note: the Web API key is not a secret (it ships in the browser); still, fill
# your own values in .env.local rather than committing them here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
